# Environment Configuration
NODE_ENV=development
PORT=3000

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/medibot_ai
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medibot_ai
DB_USER=username
DB_PASSWORD=password

# Google Calendar API
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=your_private_key_here
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Google Sheets API
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id

# Clinic Configuration
CLINIC_NAME=HealthCare Clinic
CLINIC_ADDRESS=123 Medical Street, City, Country
CLINIC_PHONE=+1234567890
CLINIC_EMERGENCY_PHONE=021xxxxxxx
CLINIC_EMAIL=info@healthcareclinic.com

# Business Hours (24-hour format)
CLINIC_START_HOUR=9
CLINIC_END_HOUR=17
APPOINTMENT_DURATION_MINUTES=30

# LLM Configuration (Optional)
OPENAI_API_KEY=your_openai_api_key
LLM_ENABLED=false

# Timezone
TIMEZONE=Asia/Colombo

# Session Configuration
SESSION_TIMEOUT_MINUTES=30

# Logging
LOG_LEVEL=info
