# Server
PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1xxxxxxxxxx

# Claude AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# Google Calendar (ONE-WAY PUSH — appointments pushed TO doctor calendars)
# Each doctor's calendar ID is stored in the doctors table (google_calendar_id column)
# Use the doctor's Gmail address as calendar ID (e.g. doctor@gmail.com)
# Leave blank to disable Google Calendar push (bookings still work fine)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REFRESH_TOKEN=your-google-oauth-refresh-token
GOOGLE_CALENDAR_ID=primary

# Dashboard auth (generate a strong random key)
DASHBOARD_API_KEY=your-secret-dashboard-api-key

# Clinic config
CLINIC_NAME=Entrust Family Clinic
GOOGLE_REVIEW_LINK=https://g.page/your-clinic/review
